{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}
{% block stylesheets %}
    <style>
        .logo-position {
            position: absolute;
            top: -190px;
            left: -50px;
            max-width: 200px;
        }
         .title-frame {
            border: 2px solid #007bff; /* Change this to the color of your choice */
            padding: 10px;
            border-radius: 5px;
            display: inline-block;
        }
    </style>
{% endblock %}
{% block body %}
<!-- CSS only -->
<link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">

<!-- JS, Popper.js, and jQuery -->
<script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>

    <div class="container py-5">
        <div class="row justify-content-center">
        <div class="col-md-8 text-center mb-4">
                <h2 class="display-4 text-primary title-frame"><b>UPF CODING CHALLENGE</b></h2>
            </div>

        <div class="col-12 text-left pl-5 mb-4">
                <img src="{{ asset('https://www.guide-metiers.ma/wp-content/uploads/2016/06/upf.couleur-min-300x300.png') }}" alt="Logo" class="img-fluid logo-position" style="max-width: 200px;">
            </div>
            <div class="col-md-8">
                <div class="card border-0 shadow-lg">
                    <div class="card-header bg-primary text-white rounded-top">
                    
                        <h1 class="mb-0">Register</h1>
                    </div>

                    <div class="card-body">
                        {{ form_start(registrationForm, { 'attr': {'class': 'form-horizontal'} }) }}
                        
                            <div class="form-group">
                                {{ form_label(registrationForm.email, 'Email', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control', 'placeholder': 'Email'}}) }}
                                {{ form_errors(registrationForm.email) }}
                            </div>

                            <div class="form-group">
                                {{ form_label(registrationForm.plainPassword, 'Password', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-control', 'placeholder': 'Password'}}) }}
                                {{ form_errors(registrationForm.plainPassword) }}
                            </div>

                            <div class="form-group form-check">
                                {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'form-check-input'}}) }}
                                {{ form_label(registrationForm.agreeTerms, 'I agree to the terms and conditions', {'label_attr': {'class': 'form-check-label'}}) }}
                                {{ form_errors(registrationForm.agreeTerms) }}
                            </div>

                            <div class="form-group">
                                <button type="submit" class="btn btn-primary btn-block">Register</button>
                            </div>
                        {{ form_end(registrationForm) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
